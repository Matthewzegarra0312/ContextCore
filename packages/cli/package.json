{
  "name": "@contextcore/cli",
  "version": "0.1.1",
  "description": "Memoria compartida y viva para los agentes de código de tu equipo — mantiene AGENTS.md/CLAUDE.md/.cursor/rules sincronizados con lo que el equipo está haciendo de verdad.",
  "type": "module",
  "bin": {
    "contextcore": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "scripts/postinstall-model.mjs"
  ],
  "keywords": [
    "agents.md",
    "claude-code",
    "cursor",
    "ai-agents",
    "context",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Matthewzegarra0312/ContextCore",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "gen:logo": "node scripts/gen-logo.mjs",
    "postinstall": "node scripts/postinstall-model.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@contextcore/core": "workspace:*",
    "dotenv": "^16.4.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.2",
    "@types/node": "^20.14.11",
    "sharp": "^0.33.5"
  }
}
