{
  "name": "contextcore",
  "version": "0.1.0",
  "description": "Memoria compartida y viva para los agentes de código de tu equipo — mantiene AGENTS.md/CLAUDE.md/.cursor/rules sincronizados con lo que el equipo está haciendo de verdad.",
  "type": "module",
  "bin": {
    "contextcore": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "agents.md",
    "claude-code",
    "cursor",
    "ai-agents",
    "context",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Matthewzegarra0312/ContextCore",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@contextcore/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.2",
    "@types/node": "^20.14.11"
  }
}
