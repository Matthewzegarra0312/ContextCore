# Opcional — si no están, el CLI funciona 100% offline (solo .jsonl local).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Opcional — anula la detección automática vía `git config user.name`.
CONTEXTCORE_AUTHOR=

# Opcional — URL del servicio de resumen (services/summarizer). Si no está
# configurado o no responde, `contextcore capture` cae al fallback local
# basado en el mensaje de commit (ver packages/core/src/captureFromCommit.ts).
SUMMARIZER_URL=http://localhost:8000
