# Opcional — si no están, el CLI funciona 100% offline (solo .jsonl local).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Opcional — anula la detección automática vía `git config user.name` (y
# también anula el github_login de `contextcore login`, si hay sesión).
CONTEXTCORE_AUTHOR=

# Opcional — dónde vive el dashboard, para `contextcore login` (device-code
# flow: abre <CONTEXTCORE_WEB_URL>/cli-login?code=... en el navegador). Sin
# esto, apunta a http://localhost:3000 (útil en dev, pero `login` necesita la
# URL real de Vercel en producción).
CONTEXTCORE_WEB_URL=http://localhost:3000

# Opcional — la IA local (node-llama-cpp + Qwen2.5-Coder 1.5B, embebida en
# @contextcore/core) está activada por defecto y se descarga sola con
# `contextcore init`. Poné "off" (o "false"/"0") para desactivarla del todo:
# ni descarga ni inferencia, y `contextcore capture` usa siempre el fallback
# local basado en el mensaje de commit (ver packages/core/src/captureFromCommit.ts).
CONTEXTCORE_AI=
