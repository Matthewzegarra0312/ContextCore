# Opcional — sin esto, /dashboard muestra datos de ejemplo (ver lib/mockEvents.ts)
# y el login (GitHub) queda deshabilitado.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Requerida solo para el login del CLI (`contextcore login`). Server-only —
# NUNCA debe llevar el prefijo NEXT_PUBLIC_ ni exponerse al browser: tiene
# permiso para saltarse RLS. Se usa en web/lib/supabaseAdmin.ts, exclusivamente
# desde las API routes /api/cli/*. Se obtiene en Supabase → Project Settings →
# API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
